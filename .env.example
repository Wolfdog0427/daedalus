# ── Daedalus Orchestrator ───────────────────────────────────────
DAEDALUS_PORT=3001
DAEDALUS_HOST=0.0.0.0
DAEDALUS_TOKEN=daedalus-dev-token

# Comma-separated list of allowed CORS origins (omit for allow-all in dev)
# DAEDALUS_CORS_ORIGINS=http://localhost:5173,http://192.168.1.100:5173

# Structured logging to file (set to "true" to enable)
# DAEDALUS_LOG_FILE=true

# ── Cockpit (Vite) ─────────────────────────────────────────────
VITE_ORCHESTRATOR_URL=http://localhost:3001
VITE_DAEDALUS_TOKEN=daedalus-dev-token
# VITE_DAEDALUS_API_BASE=/daedalus

# ── Mobile (Expo) ──────────────────────────────────────────────
# Set in app.json → extra, or via EAS build env:
# orchestratorUrl=http://10.0.2.2:3001   (Android emulator)
# orchestratorUrl=http://localhost:3001   (iOS simulator)
# daedalusToken=daedalus-dev-token
